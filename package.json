{
	"name": "svg-blur-up",
	"version": "3.1.1",
	"description": "A tool that generates image previews.",
	"homepage": "https://github.com/vanruesc/blur-up",
	"license": "Zlib",
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/types/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"bin": {
		"blur-up": "./dist/cli.js"
	},
	"keywords": [
		"lazy",
		"loading",
		"preview",
		"image",
		"embed",
		"svg",
		"base64",
		"data",
		"uri"
	],
	"author": {
		"name": "Raoul van Rüschen",
		"email": "vanruesc@outlook.de"
	},
	"repository": {
		"url": "git+https://github.com/vanruesc/blur-up.git"
	},
	"bugs": {
		"url": "https://github.com/vanruesc/blur-up/issues"
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">= 24"
	},
	"scripts": {
		"build": "run-p build:js:min build:dts",
		"build:js": "node esbuild",
		"build:js:min": "node esbuild -m",
		"build:dts": "tsc -p tsconfig.d.json",
		"clean": "del-cli dist test/generated",
		"lint": "run-p lint:*",
		"lint:js": "eslint --fix src test",
		"lint:tsc": "tsc --noEmit",
		"prepublishOnly": "npm test",
		"pretest": "run-s clean lint build",
		"test": "node --import tsx --test"
	},
	"dependencies": {
		"glob": "13.x.x",
		"sharp": "0.x.x",
		"yargs": "18.x.x"
	},
	"devDependencies": {
		"@types/node": "26.x.x",
		"@types/yargs": "17.x.x",
		"del-cli": "7.x.x",
		"esbuild": "0.28.x",
		"eslint": "10.x.x",
		"eslint-config-aether": "3.x.x",
		"npm-run-all": "4.x.x",
		"tsx": "4.x.x",
		"typescript": "6.0.x"
	}
}
